FUSION_LOGIN=
FUSION_PASSWORD=
FUSION_URL=

SAJ_URL=
SAJ_LOGIN=
SAJ_PASSWORD=

SOLIS_URL=
SOLIS_LOGIN=
SOLIS_PASSWORD=

GROWATT_URL=
GROWATT_TOKEN=
GROWATT_SN=
GROWATT_TYPE=

# Outbound mail (Gmail: use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Google Sheets — path to service account JSON file, or paste the JSON contents directly
# Option A: path to a local JSON file (keep the file outside the repo or in service-account/ which is gitignored)
# GOOGLE_CREDENTIALS_JSON=/path/to/your/service-account.json
# Option B: paste the JSON contents as a single-line string
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SHEET_ID=

# add to github secrets for automated deployment with Robocorp
ROBOCORP_CREDENTIALS=
ROBOCORP_WORKSPACE_ID=
ROBOCORP_ROBOT_ID=

# set to false locally to see the browser window; cloud always runs headless
HEADLESS=false